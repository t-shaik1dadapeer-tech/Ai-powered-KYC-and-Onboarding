# Copy to .env and set your Grafana credentials for port 3002

API_HOST_PORT=8001
PROMETHEUS_HOST_PORT=9091
PROMETHEUS_URL=http://127.0.0.1:9091

GRAFANA_URL=http://127.0.0.1:3002
GRAFANA_USER=admin
GRAFANA_PASSWORD=your-grafana-password
# Or use API token instead of user/password:
# GRAFANA_API_TOKEN=glsa_...

BUNDLED_GRAFANA_PORT=3003
