+def test_create_customer_normalizes_email_case(client):
+    response = client.post(
+        "/customers",
+        json={
+            "full_name": "Case Test",
+            "email": "Case.User@Example.COM",
+            "phone": "9876543210",
+        },
+    )
+    assert response.status_code == 201
+    assert response.json()["email"] == "case.user@example.com"
+
+
